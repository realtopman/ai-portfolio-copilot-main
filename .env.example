# Flask Configuration
SECRET_KEY=your-secret-key-here-change-in-production
FLASK_ENV=development

# Monday.com API Configuration
# Get your token from: https://monday.com/developers
MONDAY_API_TOKEN=your-monday-api-token-here

# Workspace Configuration (optional - for multiple workspaces)
# Run `python get_workspace_ids.py` to find your workspace IDs
# Only set these if you have multiple workspaces with duplicate board names
# WORKSPACE_ID_1=your-first-workspace-id
# WORKSPACE_ID_2=your-second-workspace-id
# ACTIVE_WORKSPACE_ID=your-first-workspace-id

# OpenAI Configuration
# Get your API key from: https://platform.openai.com/api-keys
OPENAI_API_KEY=your-openai-api-key-here
OPENAI_MODEL=gpt-3.5-turbo

# Optional: Advanced OpenAI Settings
# OPENAI_MODEL=gpt-4  # Use GPT-4 for more advanced reports (costs more)
